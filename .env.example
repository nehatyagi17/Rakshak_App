# Global Rakshak Configuration Template

# Django
SECRET_KEY=your-django-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# MongoDB Atlas
# Replace with your free M0 Cluster URI ending in rakshak_db?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/rakshak_db?retryWrites=true&w=majority

# File Storage (local)
MEDIA_ROOT=./media
MEDIA_URL=/media/

# Encryption (generate locally 32-url-safe-base64-encoded string: run `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`)
AES_ENCRYPTION_KEY=

# Expo Push (Free Public Endpoint API)
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send
